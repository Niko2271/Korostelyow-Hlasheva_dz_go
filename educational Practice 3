package main

import (
	"flag"
	"fmt"
	"net"
	"os"
	"os/signal"
	"syscall"
	"time"
)

func main() {
	host := flag.String("host", "google.com", "хост для проверки")
	flag.Parse()

	fmt.Printf("Проверяем хост: %s\n", *host)

	sigChan := make(chan os.Signal, 1)
	signal.Notify(sigChan, syscall.SIGINT, syscall.SIGTERM)

	resultChan := make(chan string)

	go func() {
		start := time.Now()
		conn, err := net.DialTimeout("tcp", *host+":80", 2*time.Second)
		
		if err != nil {
			resultChan <- fmt.Sprintf("%s | ОШИБКА: %v", *host, err)
			return
		}
		defer conn.Close()
		
		latency := time.Since(start)
		resultChan <- fmt.Sprintf("%s | OK | %v", *host, latency)
	}()
	select {
	case res := <-resultChan:
		fmt.Println(res)
	case <-sigChan:
		fmt.Println("\nПолучен сигнал завершения. Выходим.")
	}

	fmt.Println("Программа завершена.")
}
